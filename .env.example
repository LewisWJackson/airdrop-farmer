# Jackson Airdrop Farm — Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ─── Wallet Encryption ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# ─── Telegram Notifications ─────────────────────────────────────────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot
# 2. Get your chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── RPC Endpoints (optional — defaults to free public RPCs) ─────────────────
# For better reliability, use Alchemy/Infura free tier
# RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_MEGAETH=https://mainnet.megaeth.com/rpc
# RPC_ABSTRACT=https://api.mainnet.abs.xyz
# RPC_UNICHAIN=https://1rpc.io/unichain
